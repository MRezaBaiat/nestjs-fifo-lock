{
  "name": "nestjs-fifo-lock",
  "version": "1.0.5",
  "description": "A fifo lock using redis and nestjs",
  "author": "Reza Baiat",
  "private": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "ISC",
  "homepage": "https://github.com/MRezaBaiat/nestjs-fifo-lock#readme",
  "bugs": {
    "url": "https://github.com/MRezaBaiat/nestjs-fifo-lock/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MRezaBaiat/nestjs-fifo-lock.git"
  },
  "files": [
    "dist",
    "package.json",
    "package-lock.json"
  ],
  "scripts": {
    "delete-dist": "rimraf dist",
    "generate-dist": "npm run delete-dist && tsc --p ./tsconfig.json --declaration --declarationDir dist --outDir dist",
    "test": "jest --runInBand"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.10",
    "ioredis": "^5.8.2",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.3.1",
    "typescript": "^5.1.3",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.1",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^4.2.1",
    "prettier": "^2.8.8"
  },
  "jest": {
    "preset": "ts-jest",
    "rootDir": "src",
    "testEnvironment": "node",
    "testRegex": ".*\\.spec\\.ts$",
    "moduleFileExtensions": ["ts", "js", "json"],
    "clearMocks": true,
    "restoreMocks": true,
    "resetMocks": true
  }
}
